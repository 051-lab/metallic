{
  "manifest_version": 3,
  "name": "Gemini Utilities",
  "version": "1.1",
  "description": "This extension converts Gemini content to Markdown format and downloads your chat history.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/icon16.png",
      "48": "images/icon48.png",
      "128": "images/icon128.png"
    }
  },
  "icons": {
    "16": "images/icon16.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["clipboardRead", "clipboardWrite", "downloads", "scripting", "activeTab", "storage", "unlimitedStorage"],
  "host_permissions": ["https://gemini.google.com/*"],
  "content_scripts": [
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["turndown.min.js", "storage.js", "contentScript.js"]
    }
  ]
}
