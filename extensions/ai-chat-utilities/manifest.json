{
  "manifest_version": 3,
  "name": "AI Chat Utilities",
  "version": "2.2.0",
  "description": "Capture, export, and archive conversations from Gemini, ChatGPT, Claude, Qwen, Google AI Mode, and other AI chatbots.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "AI Chat Utilities",
    "default_icon": {
      "16": "images/icon16.png",
      "48": "images/icon48.png",
      "128": "images/icon128.png"
    }
  },
  "icons": {
    "16": "images/icon16.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  },
  "background": {
    "service_worker": "dist/background.js"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "permissions": [
    "activeTab",
    "clipboardWrite",
    "downloads",
    "scripting",
    "storage",
    "unlimitedStorage"
  ],
  "optional_host_permissions": [
    "https://*/*",
    "http://*/*"
  ]
}
